# 复制为 .env 后填写真实值（勿将 .env 提交到 Git）

# SQLite：路径相对「prisma」目录，实际文件为 prisma/dev.db
# 不要写 file:./prisma/dev.db（会变成 prisma/prisma/dev.db）
DATABASE_URL="file:./dev.db"

# 生成示例：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"
# 局域网内用手机/其他电脑访问时，改为本机 IP，例如：
# NEXTAUTH_URL="http://192.168.1.100:3000"

# 定时提醒接口 /api/cron/reminder 校验用（勿泄露）
# CRON_SECRET="your-random-secret"
# 调用示例：curl -H "Authorization: Bearer $CRON_SECRET" http://localhost:3000/api/cron/reminder

# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# 会议 AI 纪要（可选）
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# 语音转写转发地址（可选，由 /api/projects/.../transcribe 代理请求）
# SPEECH_TO_TEXT_URL=

# 定时任务会检查证书到期并推送站内通知（类型 CERT_EXPIRING），与 CRON_SECRET 共用 /api/cron/reminder
